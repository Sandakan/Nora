{
	"name": "nora",
	"version": "4.0.0-alpha.4",
	"type": "module",
	"description": "Nora",
	"devEngines": {
		"packageManager": [
			{
				"name": "npm",
				"version": "^11.6.2"
			}
		]
	},
	"keywords": [
		"music",
		"electron",
		"react",
		"typescript",
		"music-player",
		"lyrics",
		"windows",
		"desktop"
	],
	"main": "./out/main/main.js",
	"author": {
		"email": "adsandakannipunajith2003@outlook.com",
		"name": "Sandakan Nipunajith",
		"url": "https://github.com/Sandakan"
	},
	"homepage": "https://github.com/Sandakan/Nora",
	"urls": {
		"discord_invite_url": "https://discord.gg/c5rGKnBs4y",
		"raw_repository_url": "https://raw.githubusercontent.com/Sandakan/Nora/",
		"website_url": "https://noramusic.netlify.app/"
	},
	"bugs": {
		"email": "sandakannipunajith@gmail.com",
		"url": "https://github.com/Sandakan/Nora/issues"
	},
	"releaseNotes": {
		"json": "https://raw.githubusercontent.com/Sandakan/Nora/master/release-notes.json",
		"md": "https://raw.githubusercontent.com/Sandakan/Nora/master/changelog.md"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Sandakan/Nora"
	},
	"appPreferences": {
		"metadataEditingSupportedExtensions": [
			"mp3"
		],
		"removeReactStrictMode": false,
		"showSongIdInsteadOfSongYear": false,
		"supportedMusicExtensions": [
			"mp3",
			"wav",
			"ogg",
			"aac",
			"m4r",
			"m4a",
			"opus",
			"flac"
		]
	},
	"overrides": {
		"tar": "^7.5.13",
		"phin": "^3.7.1",
		"esbuild": "0.27.4",
		"cross-spawn": "^7.0.6",
		"file-type": "^21.3.1",
		"jpeg-js": "^0.4.4"
	},
	"_comments": {
		"sharp": "Using WASM build for cross-platform compatibility. Install with: npm install --cpu=wasm32 sharp",
		"prebuild:wasm": "Creates placeholder directory for Sharp platform compatibility due to package-lock.json references"
	},
	"scripts": {
		"test": "vitest run",
		"coverage": "vitest run --coverage",
		"check-types": "tsc --noEmit",
		"husky-test": "npm run format-check && npm run test",
		"prepare": "husky install",
		"format-check": "oxfmt --check",
		"format-write": "oxfmt",
		"format": "oxfmt",
		"lint": "oxlint .",
		"lint-fix": "oxlint . --fix",
		"lint-save-results": "oxlint -f json > ./lint_results.json",
		"eslint-inspector": "npx @eslint/config-inspector@latest",
		"typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
		"typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
		"typecheck": "npm run typecheck:node && npm run typecheck:web",
		"start": "electron-vite preview",
		"dev": "electron-vite dev --watch --inspect --sourcemap",
		"build": "electron-vite build",
		"prebuild:wasm": "node -e \"const fs = require('fs'); const path = require('path'); const dir = path.join(__dirname, 'node_modules', '@img', 'sharp-darwin-arm64'); if (!fs.existsSync(dir)) { fs.mkdirSync(dir, { recursive: true }); console.log('Created placeholder for Sharp platform compatibility (using WASM build)'); }\"",
		"postinstall": "electron-builder install-app-deps",
		"build:unpack": "npm run prebuild:wasm && npm run build && electron-builder --dir --publish=never",
		"build:win": "npm run prebuild:wasm && npm run build && electron-builder --win --publish=never",
		"build:win-x64": "npm run prebuild:wasm && npm run build && electron-builder --win --x64 --publish=never",
		"build:mac": "npm run prebuild:wasm && npm run build && electron-builder --mac --publish=never",
		"build:mac-arm64": "npm run prebuild:wasm && npm run build && electron-builder --mac --arm64 --publish=never",
		"build:linux": "npm run prebuild:wasm && npm run build && electron-builder --linux --publish=never",
		"build:flatpak": "npm run build && electron-builder --linux --dir --publish=never",
		"db:migrate": "drizzle-kit migrate",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:pull": "drizzle-kit pull",
		"db:studio": "drizzle-kit studio --verbose",
		"db:seed": "drizzle-kit seed",
		"db:drop": "node ./scripts/dropDatabase.ts",
		"logs": "node ./scripts/colorize-logs.ts --use-env-log-path",
		"renderer:generate-routes": "tsr generate",
		"renderer:watch-routes": "tsr watch",
		"preversion": "npm test",
		"version": "npm install && npm run build"
	},
	"dependencies": {
		"@electric-sql/pglite": "^0.4.4",
		"@electric-sql/pglite-tools": "^0.3.4",
		"@electron-toolkit/preload": "^3.0.2",
		"@headlessui/react": "^2.2.9",
		"@hello-pangea/dnd": "^18.0.1",
		"@lukemorales/query-key-factory": "^1.3.4",
		"@neos21/detect-chinese": "^0.0.2",
		"@sglkc/kuroshiro": "^1.0.1",
		"@sglkc/kuroshiro-analyzer-kuromoji": "^1.0.1",
		"@tanstack/react-pacer": "^0.22.0",
		"@tanstack/react-query": "^5.96.1",
		"@tanstack/react-query-devtools": "^5.96.1",
		"@tanstack/react-router": "^1.168.10",
		"@tanstack/react-store": "^0.11.0",
		"@vitalets/google-translate-api": "^9.2.1",
		"@vitejs/plugin-react": "^6.0.1",
		"didyoumean2": "^7.0.4",
		"discord-rpc": "^4.0.1",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.2",
		"electron-store": "^11.0.2",
		"electron-updater": "^6.8.3",
		"es-toolkit": "^1.45.1",
		"i18next": "^26.0.3",
		"mime": "^4.1.0",
		"node-taglib-sharp": "^6.0.1",
		"node-vibrant": "^4.0.4",
		"pinyin-pro": "^3.28.0",
		"react-i18next": "^17.0.2",
		"react-virtuoso": "^4.18.4",
		"romaja": "^0.2.9",
		"segmentit": "^2.0.3",
		"sharp": "^0.34.5",
		"songlyrics": "^2.4.8",
		"tailwind-merge": "^3.5.0",
		"wanakana": "^5.3.1",
		"winston": "^3.19.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@electron-toolkit/tsconfig": "^2.0.0",
		"@rolldown/plugin-babel": "^0.2.3",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/react-router-devtools": "^1.166.11",
		"@tanstack/router-cli": "^1.166.25",
		"@tanstack/router-plugin": "^1.167.12",
		"@types/babel__core": "^7.20.5",
		"@types/discord-rpc": "^4.0.1",
		"@types/node": "^25.5.0",
		"@types/pinyin": "^2.10.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitest/coverage-v8": "^4.1.2",
		"babel-plugin-react-compiler": "^1.0.0",
		"drizzle-kit": "^0.31.1",
		"electron": "^41.1.0",
		"electron-builder": "^26.8.1",
		"electron-devtools-installer": "^4.0.0",
		"electron-vite": "^6.0.0-beta.1",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"material-symbols": "^0.44.0",
		"oxfmt": "^0.48.0",
		"oxlint": "^1.58.0",
		"oxlint-tsgolint": "^0.22.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.2",
		"yoctocolors": "^2.1.2"
	}
}
